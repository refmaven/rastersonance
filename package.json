{
  "name": "rastersonance",
  "version": "1.0.0",
  "description": "A high-performance 2D graphics library built with WebGL2",
  "main": "dist/rastersonance.js",
  "module": "src/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/rastersonance.js",
      "browser": "./dist/rastersonance.min.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "python -m http.server 3000",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "webgl2",
    "graphics",
    "2d",
    "canvas",
    "rendering"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/rastersonance.git"
  }
}
