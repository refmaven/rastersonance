{
  "name": "rastersonance",
  "version": "1.0.0",
  "description": "a 2d graphics library built on top of webgl2",
  "main": "./dist/rastersonance.umd.js",
  "module": "./dist/rastersonance.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/rastersonance.esm.js",
      "require": "./dist/rastersonance.umd.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "python -m http.server 3000",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "webgl2",
    "graphics",
    "2d",
    "canvas",
    "rendering"
  ],
  "license": "MIT"
}
